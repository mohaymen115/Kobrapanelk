# جلب الرسائل من TimeSMS
# =======================
class TimeSMSClient:
    def __init__(self):
        self.session = requests.Session()
        self.session.headers.update({
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
            'Accept-Language': 'en-US,en;q=0.9',
        })
        self.logged_in = False
        
    def login(self):
        """تسجيل الدخول إلى TimeSMS"""
        try:
            print("🔑 جاري تسجيل الدخول...")
            
            # جلب صفحة login
            resp = self.session.get(f"{BASE_URL}/login", timeout=15)
            if resp.status_code != 200:
                print(f"❌ فشل في جلب صفحة login: {resp.status_code}")
                return False
            
            # حل الكابتشا
            captcha = solve_captcha(resp.text)
            if not captcha:
                print("❌ لم نتمكن من حل الكابتشا")
                return False
            
            print(f"🧮 الكابتشا: {captcha}")
            
            # إرسال بيانات الدخول
            login_resp = self.session.post(
                f"{BASE_URL}/signin",
                data={'username': TIMESMS_USERNAME, 'password': TIMESMS_PASSWORD, 'capt': captcha},
                headers={'Referer': f"{BASE_URL}/login"},
                timeout=15,
                allow_redirects=True
            )
            
            # التحقق من نجاح الدخول
            self.logged_in = 'login' not in login_resp.url.lower()
            
            if self.logged_in:
                print("✅ تم تسجيل الدخول بنجاح")
                # زيارة صفحة التقارير
                reports_url = f"{BASE_URL}/agent/SMSCDRReports"
                self.session.get(reports_url, timeout=10)
                return True
            else:
                print(f"❌ فشل تسجيل الدخول: {login_resp.url}")
                return False
            
        except Exception as e:
            print(f"❌ خطأ في تسجيل الدخول: {e}")
            return False
    
    def fetch_sms(self):
        """جلب رسائل SMS"""
        if not self.logged_in and not self.login():
            return None
        
        try:
            today = datetime.now().strftime('%Y-%m-%d')
            
            reports_url = f"{BASE_URL}/agent/SMSCDRReports"
            
            # نجرب AJAX مع headers صح
            url = f"{BASE_URL}/agent/res/data_smscdr.php"
            params = {
                'fdate1': f"{today} 00:00:00",
                'fdate2': f"{today} 23:59:59",
                'frange': '',
                'fclient': '',
                'fnum': '',
                'fcli': '',
                'fg': '0',
                'sEcho': '1',
                'iDisplayStart': '0',
                'iDisplayLength': '500'
            }
            
            headers = {
                'Referer': reports_url,
                'X-Requested-With': 'XMLHttpRequest',
                'Accept': 'application/json, text/javascript, */*; q=0.01'
            }
            
            resp = self.session.get(url, params=params, headers=headers, timeout=15)
            
            if resp.status_code != 200:
                print(f"❌ خطأ في الاستجابة: {resp.status_code}")
                return None
            
            try:
                data = resp.json()
            except:
                print("⚠️ الاستجابة مش JSON")
                return None
            
            rows = data.get('aaData', [])
            records = []
            
            for row in rows:
                if len(row) < 9:
                    continue
                    
                sms_text = str(row[5]) if row[5] else ''
                
                record = {
                    'sms_date': str(row[0]) if len(row) > 0 else '',
                    'country_range': str(row[1]) if len(row) > 1 else '',
                    'phone_number': str(row[2]) if len(row) > 2 else '',
                    'cli_number': str(row[3]) if len(row) > 3 else '',
                    'client_name': str(row[4]) if len(row) > 4 and row[4] != 'None' else '',
                    'message_text': sms_text,
                    'currency_type': str(row[6]) if len(row) > 6 else '',
                    'my_earnings': str(row[7]) if len(row) > 7 else '',
                    'client_earnings': str(row[8]) if len(row) > 8 else '',
                }
                
                record['otp_code'] = extract_otp(sms_text) or ''
                record['service_name'] = detect_service(record['cli_number'], sms_text)
                
                if record['otp_code']:
                    records.append(record)
            
            print(f"📊 تم جلب {len(records)} رسالة")
            return records
            
        except Exception as e:
            print(f"❌ خطأ في جلب الرسائل: {e}")
            return None

