@app.route("/")
def home():
    try:
        conn = sqlite3.connect(DB_FILE)
        c = conn.cursor()
        c.execute("""
            SELECT sms_date, country_range, phone_number, cli_number, 
                   message_text, otp_code, service_name 
            FROM sms_records 
            ORDER BY id DESC 
            LIMIT 100
        """)
        rows = c.fetchall()
        conn.close()
        
        messages = []
        for r in rows:
            messages.append({
                "sms_date": r[0],
                "country_range": r[1],
                "phone_number": r[2],
                "cli_number": r[3],
                "message_text": r[4],
                "otp_code": r[5],
                "service_name": r[6]
            })
        
        current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        return render_template_string(HTML_TEMPLATE, messages=messages, current_time=current_time)
    
    except Exception as e:
        print(f"❌ خطأ في الصفحة: {e}")
        current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        return render_template_string(HTML_TEMPLATE, messages=[], current_time=current_time)

# =======================
# مراقبة TimeSMS
# =======================
def monitor_timesms():
    """مراقبة موقع TimeSMS وجلب الرسائل"""
    print("🚀 بدء مراقبة TimeSMS.net...")
    
    client = TimeSMSClient()
    processed = set()
    
    # نجلب الرسائل الموجودة أولاً
    print("📥 جلب الرسائل الموجودة...")
    records = client.fetch_sms()
    if records:
        saved = 0
        for record in records:
            # إنشاء hash فريد
            hash_str = f"{record['sms_date']}-{record['phone_number']}-{record['otp_code']}"
            record_hash = hashlib.md5(hash_str.encode()).hexdigest()
            
            if record_hash not in processed:
                processed.add(record_hash)
                
                conn = sqlite3.connect(DB_FILE)
                c = conn.cursor()
                c.execute("""
                    INSERT INTO sms_records 
                    (sms_date, country_range, phone_number, cli_number, 
                     message_text, otp_code, service_name, created_at) 
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                """, (
                    record['sms_date'], record['country_range'], record['phone_number'], 
                    record['cli_number'], record['message_text'],
                    record['otp_code'], record['service_name'],
                    datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                ))
                conn.commit()
                conn.close()
                saved += 1
        
        print(f"✅ تم حفظ {saved} رسالة من TimeSMS")
    
    # مراقبة مستمرة
    fail_count = 0
    while True:
        try:
            records = client.fetch_sms()
            
            if records:
                fail_count = 0
                for record in records:
                    hash_str = f"{record['sms_date']}-{record['phone_number']}-{record['otp_code']}"
                    record_hash = hashlib.md5(hash_str.encode()).hexdigest()
                    
                    if record_hash not in processed:
                        processed.add(record_hash)
                        
                        conn = sqlite3.connect(DB_FILE)
                        c = conn.cursor()
                        c.execute("""
                            INSERT INTO sms_records 
                            (sms_date, country_range, phone_number, cli_number, 
                             message_text, otp_code, service_name, created_at) 
                            VALUES (?, ?, ?, ?, ?, ?, ?, ?)
                        """, (
                            record['sms_date'], record['country_range'], record['phone_number'], 
                            record['cli_number'], record['message_text'],
                            record['otp_code'], record['service_name'],
                            datetime.now().strftime("%Y-%m-%d %H:%M:%S")
                        ))
                        conn.commit()
                        conn.close()
                        
                        print(f"\n📩 رسالة جديدة من TimeSMS!")
                        print(f"   📱 رقم: {record['phone_number']}")
                        print(f"   🔑 OTP: {record['otp_code']}")
            else:
                fail_count += 1
                if fail_count % 5 == 0:
                    print(f"⚠️ {fail_count} محاولات فاشلة متتالية...")
            
            time.sleep(5)
            
        except Exception as e:
            print(f"❌ خطأ في المراقبة: {e}")
            time.sleep(10)

