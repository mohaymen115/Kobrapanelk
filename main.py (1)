# دوال مساعدة
# =======================
def extract_otp(text):
    """استخراج OTP من النص"""
    if not text:
        return None
    patterns = [
        r'(\d{3}[\-\s]?\d{3})',
        r'code[:\s]*(\d{4,8})',
        r'(\d{6})',
        r'(\d{4,8})',
    ]
    for p in patterns:
        m = re.search(p, text, re.IGNORECASE)
        if m:
            return m.group(1).replace(' ', '').replace('-', '')
    return None

def detect_service(cli_text, sms_text=''):
    """كشف الخدمة"""
    combined = f"{cli_text} {sms_text}".lower()
    services = {
        'WhatsApp': ['whatsapp', 'واتساب', 'واتس'],
        'Telegram': ['telegram', 'تلغرام', 'تليجرام'],
        'Google': ['google', 'gmail', 'جوجل'],
        'Facebook': ['facebook', 'فيسبوك', 'meta'],
        'Instagram': ['instagram', 'انستغرام', 'انستا'],
        'TikTok': ['tiktok', 'تيك توك'],
    }
    for service, keywords in services.items():
        for kw in keywords:
            if kw in combined:
                return service
    return cli_text or 'SMS'

def solve_captcha(html):
    """حل الكابتشا"""
    match = re.search(r'(\d+)\s*([+\-*/])\s*(\d+)\s*=?\s*\?', html)
    if match:
        n1, op, n2 = int(match.group(1)), match.group(2), int(match.group(3))
        if op == '+':
            return str(n1 + n2)
        elif op == '-':
            return str(n1 - n2)
        elif op == '*':
            return str(n1 * n2)
        elif op == '/':
            return str(n1 // n2) if n2 else '0'
    return None

